<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title || 'Datastar + Bun Test' }}</title>
    @!section('styles')
    <style>
        .loading { opacity: 0.5; }
        .success { color: green; }
        .error { color: red; }
        .counter-box {
            margin-top: 20px;
            padding: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    @!section('content')

    {{-- Load Datastar and initialize monitoring --}}
    <script type="module">
        // Import Datastar
        import 'https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.0-beta.11/bundles/datastar.js';

        // Wait for Datastar to be ready
        window.addEventListener('datastar-ready', () => {
            console.log('Datastar ready');
            
            // Monitor SSE events
            window.addEventListener('datastar-merge-fragments', (e) => {
                console.log('Received fragment:', e.detail);
                document.querySelector('[data-signals]').setAttribute('data-signals', JSON.stringify({
                    ...JSON.parse(document.querySelector('[data-signals]').getAttribute('data-signals')),
                    fragmentsStatus: 'connected'
                }));
            });
            
            window.addEventListener('datastar-merge-signals', (e) => {
                console.log('Received signals:', e.detail);
                document.querySelector('[data-signals]').setAttribute('data-signals', JSON.stringify({
                    ...JSON.parse(document.querySelector('[data-signals]').getAttribute('data-signals')),
                    connectionStatus: 'connected'
                }));
            });

            // Monitor SSE connection state
            const originalGet = window.datastar.get;
            window.datastar.get = function(...args) {
                console.log('SSE Connection attempt:', args);
                const result = originalGet.apply(this, args);
                result.catch(error => {
                    console.error('SSE Connection error:', error);
                    const signalsEl = document.querySelector('[data-signals]');
                    const currentSignals = JSON.parse(signalsEl.getAttribute('data-signals'));
                    
                    // Determine which connection failed based on the URL
                    if (args[0].includes('message-count')) {
                        currentSignals.connectionStatus = 'error';
                    } else if (args[0].includes('fragments')) {
                        currentSignals.fragmentsStatus = 'error';
                    }
                    
                    signalsEl.setAttribute('data-signals', JSON.stringify(currentSignals));
                });
                return result;
            };
        });

        // Global error handler
        window.addEventListener('error', (e) => {
            console.error('Global error:', e);
            try {
                const signalsEl = document.querySelector('[data-signals]');
                if (signalsEl) {
                    const currentSignals = JSON.parse(signalsEl.getAttribute('data-signals') || '{}');
                    signalsEl.setAttribute('data-signals', JSON.stringify({
                        ...currentSignals,
                        connectionStatus: 'error',
                        fragmentsStatus: 'error'
                    }));
                }
            } catch (err) {
                console.error('Error updating connection status:', err);
            }
        });
    </script>
</body>
</html> 